---
import { BRAND } from '../lib/constants';
import LandingIcon from './LandingIcon.astro';

interface Props {
  active?: 'general' | 'vehiculos';
}

const { active = 'general' } = Astro.props;
const waUrl = `https://wa.me/${BRAND.whatsapp}?text=${encodeURIComponent('Hola, me gustaría información sobre RK Inversiones')}`;
---

<header class="lk-nav">
  <a href="/" class="lk-nav__brand">
    <img src="/brand/logo.jpeg" alt="" width="36" height="36" />
    <span>{BRAND.name}</span>
  </a>
  <nav class="lk-nav__links" aria-label="Principal">
    <a href="/" class:list={['lk-nav__link', active === 'general' && 'is-active']}>
      <LandingIcon name="home" size={16} />
      Inicio
    </a>
    <a href="/vehiculos" class:list={['lk-nav__link', active === 'vehiculos' && 'is-active']}>
      <LandingIcon name="car" size={16} />
      Vehículos
    </a>
    <a href="/solicitar" class="lk-nav__link">
      <LandingIcon name="send" size={16} />
      Solicitar
    </a>
  </nav>
  <div class="lk-nav__actions">
    <a href="/solicitar" class="lk-nav__cta">
      <LandingIcon name="send" size={15} />
      Solicitar
    </a>
    <a href={waUrl} class="lk-nav__wa" target="_blank" rel="noopener noreferrer">
      <LandingIcon name="whatsapp" size={16} />
      <span class="lk-nav__wa-label">WhatsApp</span>
    </a>
  </div>
</header>
