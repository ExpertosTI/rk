---
const umamiUrl = (import.meta.env.PUBLIC_UMAMI_URL || '').replace(/\/$/, '');
const websiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID || '';
---

{umamiUrl && websiteId && (
  <script
    defer
    src={`${umamiUrl}/script.js`}
    data-website-id={websiteId}
    data-domains="rk.renace.tech,localhost"
  />
)}
