---
import LandingLayout from '../layouts/LandingLayout.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import FlyerChrome from '../components/FlyerChrome.astro';
import { BRAND } from '../lib/constants';
import { GENERAL_PAGE, PRODUCT_LINKS, FOOTER } from '../lib/landing';

const waUrl = `https://wa.me/${BRAND.whatsapp}?text=${encodeURIComponent('Hola, me gustaría información sobre RK Inversiones')}`;
---

<LandingLayout
  title={`${BRAND.name} — Financiamiento`}
  description="Financiamiento de apartamentos, casas, vehículos y solares. Aprobación inmediata en República Dominicana."
>
  <FlyerChrome active="general" />

  <main class="flyer-page" id="main">
    <section class="flyer-visual flyer-visual-general" aria-label="Financiamiento RK">
      <img
        src={GENERAL_PAGE.image}
        alt={`${BRAND.name} — ${GENERAL_PAGE.subtitle}`}
        class="flyer-visual-img"
        width="1080"
        height="1080"
        loading="eager"
      />
      <div class="flyer-visual-overlay">
        <p class="flyer-brand-tag">{BRAND.slogan}</p>
        <h1 class="flyer-title">{GENERAL_PAGE.title}</h1>
        <p class="flyer-sub">{GENERAL_PAGE.subtitle}</p>
      </div>
    </section>

    <section class="flyer-panel">
      <h2 class="flyer-panel-title">Elige tu financiamiento</h2>
      <ul class="flyer-links">
        {PRODUCT_LINKS.map((item) => (
          <li>
            <a href={item.href} class="flyer-link-card">
              <span class="flyer-link-check" aria-hidden="true">✓</span>
              <span class="flyer-link-label">{item.label}</span>
              <span class="flyer-link-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>

      <div class="flyer-actions">
        <a href={GENERAL_PAGE.ctaHref} class="flyer-btn flyer-btn-primary">
          {GENERAL_PAGE.cta}
        </a>
        <a href={waUrl} class="flyer-btn flyer-btn-wa" target="_blank" rel="noopener noreferrer">
          WhatsApp · {FOOTER.phone}
        </a>
      </div>

      <p class="flyer-contact">
        <a href={`tel:${FOOTER.phone.replace(/-/g, '')}`}>{FOOTER.phone}</a>
      </p>
    </section>
  </main>

  <WhatsAppFloat />
</LandingLayout>
