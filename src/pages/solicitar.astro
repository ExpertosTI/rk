---
import FormLayout from '../layouts/FormLayout.astro';
import CreditForm from '../components/react/CreditForm';
import TrustBadges from '../components/react/TrustBadges';
import LegalFooter from '../components/LegalFooter.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { MARKETING, type ProductKey } from '../lib/constants';

const producto = Astro.url.searchParams.get('producto');
const validProducts = ['apartamentos', 'casas', 'vehiculos', 'solares'];
const initialProduct = validProducts.includes(producto ?? '')
  ? (producto as ProductKey)
  : undefined;
---

<FormLayout>
  <h1 class="form-title">Tu solicitud de crédito</h1>
  <p class="form-subtitle">
    {MARKETING.approval}. Completa el formulario y un asesor te contacta por WhatsApp.
  </p>

  <TrustBadges client:load />

  <CreditForm client:load initialProduct={initialProduct} />

  <LegalFooter slot="footer" />
  <WhatsAppFloat slot="float" />
</FormLayout>
