---
import LandingLayout from '../layouts/LandingLayout.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import FlyerChrome from '../components/FlyerChrome.astro';
import { BRAND } from '../lib/constants';
import { VEHICULOS_PAGE, FOOTER } from '../lib/landing';

const waUrl = `https://wa.me/${BRAND.whatsapp}?text=${encodeURIComponent('Hola, me interesa financiamiento de vehículo con RK Inversiones')}`;
---

<LandingLayout
  title={`Financiamiento de Vehículos — ${BRAND.name}`}
  description="Financiamiento de vehículos nuevos y usados. Hasta 60 meses. Aprobación inmediata."
>
  <FlyerChrome active="vehiculos" />

  <main class="lk lk--vehiculos" id="main">
    <section class="lk-hero lk-hero--photo" data-landing-hero>
      <div class="lk-hero__bg" aria-hidden="true">
        <img src={VEHICULOS_PAGE.image} alt="" width="1080" height="1080" loading="eager" />
      </div>
      <div class="lk-hero__scrim" aria-hidden="true"></div>

      <figure class="lk-photo" data-reveal-instant aria-hidden="false">
        <img
          src={VEHICULOS_PAGE.image}
          alt="Cliente recibiendo las llaves de su vehículo"
          width="1080"
          height="1080"
          loading="eager"
        />
      </figure>
    </section>

    <section class="lk-intro" data-reveal>
      <p class="lk-eyebrow">{VEHICULOS_PAGE.hero.eyebrow}</p>
      <h1 class="lk-title">{VEHICULOS_PAGE.hero.title}</h1>
      <p class="lk-lead">{VEHICULOS_PAGE.hero.lead}</p>
    </section>

    <section class="lk-section lk-section--dark" data-reveal>
      <div class="lk-metrics">
        <div class="lk-metric" data-reveal-item>
          <span class="lk-metric__value">
            <span data-count={VEHICULOS_PAGE.plazo}>0</span>
          </span>
          <span class="lk-metric__label">meses para pagar</span>
        </div>
        <div class="lk-metric lk-metric--line" data-reveal-item>
          <span class="lk-metric__icon" aria-hidden="true">✓</span>
          <span class="lk-metric__label">Sin importar tu historial</span>
        </div>
      </div>

      <div class="lk-bar lk-bar--inline">
        <a href={VEHICULOS_PAGE.ctaHref} class="lk-btn lk-btn--primary lk-btn--wide">
          {VEHICULOS_PAGE.cta}
        </a>
        <a href={waUrl} class="lk-btn lk-btn--ghost" target="_blank" rel="noopener noreferrer">
          WhatsApp · {FOOTER.phone}
        </a>
        <a href="/" class="lk-link">← Otros productos</a>
      </div>
    </section>
  </main>

  <WhatsAppFloat />
</LandingLayout>
