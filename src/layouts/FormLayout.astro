---
import '../styles/global.css';
import { BRAND } from '../lib/constants';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Solicitar Crédito — RK Inversiones',
  description = 'Solicita tu crédito en minutos. Financiamiento de apartamentos, casas, vehículos y solares.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/brand/logo.jpeg" type="image/jpeg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="page">
      <div class="page-inner">
        <div class="form-card" role="main">
          <header class="card-header">
            <a href="/" class="brand-link">
              <img src="/brand/logo.jpeg" alt={BRAND.name} class="brand-logo" />
            </a>
            <div class="assist-badge">
              <div class="assist-avatar">RK</div>
              <div class="assist-text">
                <small>Te asiste</small>
                <strong>{BRAND.advisor}</strong>
              </div>
            </div>
          </header>

          <slot />
        </div>

        <slot name="footer" />
      </div>
    </div>
    <slot name="float" />
  </body>
</html>
