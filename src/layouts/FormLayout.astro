---
import '../styles/global.css';
import { BRAND } from '../lib/constants';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Solicitar Crédito — RK Inversiones',
  description = 'Solicita tu crédito en minutos. Financiamiento de apartamentos, casas, vehículos y solares.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/brand/logo.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <img src="/brand/logo-dark.png" alt={BRAND.name} class="brand-logo" height="40" />
        <a href={`https://wa.me/${BRAND.whatsapp}`} class="header-cta" target="_blank" rel="noopener">
          {BRAND.phone}
        </a>
      </div>
    </header>

    <main class="page">
      <div class="page-inner">
        <div class="form-card" role="main">
          <slot />
        </div>
      </div>
    </main>

    <slot name="float" />
  </body>
</html>
